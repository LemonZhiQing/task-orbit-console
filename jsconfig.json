{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        },
        "types": [
            "vite/client"
        ],
        "jsx": "preserve",
        "allowJs": true,
        "checkJs": false,
        "strict": false
    },
    "include": [
        "src/**/*.js",
        "src/**/*.ts",
        "src/**/*.vue",
        "vite.config.js"
    ]
}